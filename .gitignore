# ════════════════════════════════════════════════════════════
#  MediManage .gitignore
# ════════════════════════════════════════════════════════════

# ── Build Output ──────────────────────────────────────────
target/
!**/src/main/**/target/
!**/src/test/**/target/
build/
!**/src/main/**/build/
!**/src/test/**/build/
dist/

# ── IDE: IntelliJ IDEA ───────────────────────────────────
.idea/
*.iws
*.iml
*.ipr

# ── IDE: Eclipse ──────────────────────────────────────────
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# ── IDE: NetBeans ─────────────────────────────────────────
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/

# ── IDE: VS Code ─────────────────────────────────────────
.vscode/

# ── AI Agents ─────────────────────────────────────────────
.gemini/
.agent/

# ── OS Files ──────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Database ──────────────────────────────────────────────
*.db
*.db.bak
*.db.backup_*
*.db.backup-*
*.sqlite
*.sqlite3
# Allow the bundled resource database to be tracked
!src/main/resources/db/medimanage.db

# ── Python (ai_engine) ───────────────────────────────────
ai_engine/envs/
ai_engine/.venv*/
ai_engine/__pycache__/
__pycache__/
*.py[cod]
*$py.class
.venv/
env/
venv/

# ── AI Models & Output ───────────────────────────────────
models/
Output/

# ── Installer & Binaries ─────────────────────────────────
*.exe
*.msi
*.dmg
*.pkg
*.deb
*.rpm

# ── Logs ──────────────────────────────────────────────────
*.log

# ── Generated Invoices ───────────────────────────────────
Invoice_*.pdf

# ── Maven Wrapper (keep jar) ─────────────────────────────
!.mvn/wrapper/maven-wrapper.jar
whatsapp-server/.wwebjs_auth/
whatsapp-server/node_modules/
whatsapp-server/.env

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.MediManage.MedicineSearchController">

    <top>
        <VBox spacing="10" styleClass="card" style="-fx-background-radius: 0;">
            <Label text="Medicine Search" styleClass="page-title"/>
            <TextField fx:id="txtSearch" promptText="Search by Name, Company, or Brand..." style="-fx-font-size: 14px; -fx-padding: 10;"/>
        </VBox>
    </top>

    <center>
        <TableView fx:id="searchTable">
            <columns>
                <TableColumn fx:id="colName" text="Medicine Name" prefWidth="200"/>
                <TableColumn fx:id="colCompany" text="Company" prefWidth="150"/>
                <TableColumn fx:id="colLocation" text="Loc" prefWidth="80"/>
                <TableColumn fx:id="colStock" text="Stock" prefWidth="80"/>
                <TableColumn fx:id="colExpiry" text="Expiry Date" prefWidth="100"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </center>

    <right>
        <VBox fx:id="detailsPanel" spacing="15" styleClass="dark-form-panel" style="-fx-border-color: -fx-border-default; -fx-border-width: 0 0 0 1;" prefWidth="300" visible="false">
            <Label text="Drug Details" styleClass="section-title"/>

            <VBox spacing="5" styleClass="dark-section">
                <Label text="Name" styleClass="text-muted"/>
                <Label fx:id="lblDetailName" text="-" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Manufacturer" styleClass="text-muted"/>
                <Label fx:id="lblDetailCompany" text="-"/>
            </VBox>

            <Separator/>

            <VBox spacing="5">
                <Label text="Clinical Info" styleClass="text-muted"/>
                <Label fx:id="lblDetailGeneric" text="Generic: -" wrapText="true"/>
                <Label fx:id="lblDetailSideEffects" text="Notes: -" wrapText="true"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
            <Label text="Pharmacist Note: Check physical expiry before dispensing." styleClass="text-warning" style="-fx-font-size: 11px; -fx-font-style: italic;" wrapText="true"/>
        </VBox>
    </right>

</BorderPane>

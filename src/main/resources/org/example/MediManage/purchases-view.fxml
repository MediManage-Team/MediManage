<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" styleClass="dark-panel" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.MediManage.controller.PurchasesController">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <Label text="📦 Purchase Management (Production Stock Inward)" styleClass="page-title"/>

    <VBox VBox.vgrow="ALWAYS">
        <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

            <Tab text="New Purchase Order">
                <SplitPane dividerPositions="0.64" VBox.vgrow="ALWAYS">
                    <VBox spacing="10" styleClass="dark-panel">
                        <Label text="Current Order Items" styleClass="label-strong"/>
                        <TableView fx:id="poTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colMedicine" text="Medicine" prefWidth="180"/>
                                <TableColumn fx:id="colCompany" text="Company" prefWidth="120"/>
                                <TableColumn fx:id="colBatch" text="Batch" prefWidth="95"/>
                                <TableColumn fx:id="colExpiry" text="Expiry" prefWidth="95"/>
                                <TableColumn fx:id="colQty" text="Qty" prefWidth="70"/>
                                <TableColumn fx:id="colCost" text="Cost" prefWidth="95"/>
                                <TableColumn fx:id="colSell" text="Sell" prefWidth="95"/>
                                <TableColumn fx:id="colTotal" text="Total" prefWidth="105"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>

                        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="dark-section">
                            <Label text="Order Total:" styleClass="total-label"/>
                            <Label fx:id="lblTotalAmount" text="₹ 0.00" styleClass="total-value"/>
                        </HBox>

                        <Button text="🗑 Remove Selected Item" onAction="#handleRemoveItem" styleClass="button-outlined"/>
                    </VBox>

                    <ScrollPane fitToWidth="true" hbarPolicy="NEVER">
                        <content>
                            <VBox spacing="15" styleClass="billing-controls">
                                <VBox spacing="6" styleClass="billing-section">
                                    <Label text="1. Supplier / Invoice Context" styleClass="label-strong"/>
                                    <ComboBox fx:id="comboSupplier" promptText="Select Supplier" maxWidth="Infinity"/>
                                    <TextField fx:id="txtNotes" promptText="Invoice # / GRN / Purchase Notes"/>
                                </VBox>

                                <VBox spacing="10" styleClass="billing-section">
                                    <Label text="2. Medicine Selection" styleClass="label-strong"/>
                                    <CheckBox fx:id="chkNewMedicine" text="Add a brand-new medicine from Purchases" onAction="#handleMedicineModeChanged"/>

                                    <VBox fx:id="existingMedicineBox" spacing="6">
                                        <Label text="Search Existing Medicine"/>
                                        <StackPane alignment="TOP_LEFT">
                                            <TextField fx:id="txtSearchMedicine" promptText="Type medicine name / generic / company..."/>
                                            <ListView fx:id="listMedicineSuggestions" visible="false" managed="false" maxHeight="180"/>
                                        </StackPane>
                                        <Label fx:id="lblMedicineContext" text="Select an existing medicine to prefill pricing and expiry." wrapText="true" styleClass="text-muted"/>
                                    </VBox>

                                    <VBox fx:id="newMedicineBox" spacing="8" visible="false" managed="false">
                                        <GridPane hgap="10" vgap="8">
                                            <columnConstraints>
                                                <ColumnConstraints percentWidth="50"/>
                                                <ColumnConstraints percentWidth="50"/>
                                            </columnConstraints>
                                            <children>
                                                <VBox spacing="2" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                                    <Label text="Medicine Name"/>
                                                    <TextField fx:id="txtNewMedicineName" promptText="e.g. Amoxycillin 500"/>
                                                </VBox>
                                                <VBox spacing="2" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                                    <Label text="Generic Name"/>
                                                    <TextField fx:id="txtNewGenericName" promptText="e.g. Amoxicillin"/>
                                                </VBox>
                                                <VBox spacing="2" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                                    <Label text="Company / Manufacturer"/>
                                                    <TextField fx:id="txtNewCompany" promptText="e.g. Cipla"/>
                                                </VBox>
                                                <VBox spacing="2" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                                    <Label text="Reorder Level"/>
                                                    <TextField fx:id="txtNewReorderThreshold" promptText="10"/>
                                                </VBox>
                                            </children>
                                        </GridPane>
                                    </VBox>
                                </VBox>

                                <VBox spacing="10" styleClass="billing-section">
                                    <Label text="3. Batch / Pricing Details" styleClass="label-strong"/>
                                    <GridPane hgap="10" vgap="8">
                                        <columnConstraints>
                                            <ColumnConstraints percentWidth="50"/>
                                            <ColumnConstraints percentWidth="50"/>
                                        </columnConstraints>
                                        <children>
                                            <VBox spacing="2" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                                <Label text="Batch / Lot Number"/>
                                                <TextField fx:id="txtBatchNumber" promptText="e.g. B240318A"/>
                                            </VBox>
                                            <VBox spacing="2" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                                <Label text="Buying Date"/>
                                                <DatePicker fx:id="datePurchaseDate"/>
                                            </VBox>

                                            <VBox spacing="2" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                                <Label text="Expiry Date"/>
                                                <DatePicker fx:id="dateExpiryDate"/>
                                            </VBox>
                                            <VBox spacing="2" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                                <Label text="Received Qty"/>
                                                <TextField fx:id="txtQty" promptText="e.g. 50"/>
                                            </VBox>

                                            <VBox spacing="2" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                                <Label text="Unit Cost (₹)"/>
                                                <TextField fx:id="txtCost" promptText="e.g. 10.50"/>
                                            </VBox>
                                            <VBox spacing="2" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                                <Label text="Selling Price (₹)"/>
                                                <TextField fx:id="txtSellingPrice" promptText="e.g. 14.99"/>
                                            </VBox>
                                        </children>
                                    </GridPane>
                                </VBox>

                                <Button text="ADD LINE ITEM" onAction="#handleAddItem" styleClass="button-primary" maxWidth="Infinity" prefHeight="42"/>
                                <Region VBox.vgrow="ALWAYS"/>
                                <Button fx:id="btnReceiveOrder" text="RECEIVE ORDER &amp; UPDATE STOCK" onAction="#handleReceiveOrder" disable="true" maxWidth="Infinity" prefHeight="60" styleClass="button-success button-xl"/>
                            </VBox>
                        </content>
                    </ScrollPane>
                </SplitPane>
            </Tab>

            <Tab text="Purchase History">
                <VBox spacing="10" styleClass="dark-panel">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button text="🔄 Refresh History" onAction="#handleRefreshHistory" styleClass="button-outlined"/>
                    </HBox>
                    <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="histColId" text="PO #" prefWidth="80"/>
                            <TableColumn fx:id="histColDate" text="Date" prefWidth="150"/>
                            <TableColumn fx:id="histColSupplier" text="Supplier" prefWidth="200"/>
                            <TableColumn fx:id="histColAmount" text="Amount" prefWidth="120"/>
                            <TableColumn fx:id="histColStatus" text="Status" prefWidth="100"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                    <Label text="Double-click a row to inspect batch, expiry, and pricing details." styleClass="text-muted"/>
                </VBox>
            </Tab>

        </TabPane>
    </VBox>
</VBox>

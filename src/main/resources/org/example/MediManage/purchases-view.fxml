<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" styleClass="dark-panel" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.MediManage.controller.PurchasesController">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <Label text="📦 Purchase Management (Stock Inward)" styleClass="page-title"/>

    <VBox VBox.vgrow="ALWAYS">
        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
            
            <!-- Tab 1: Create New Purchase -->
            <Tab text="New Purchase Order">
                <SplitPane dividerPositions="0.65" VBox.vgrow="ALWAYS">
                    <!-- Left: Cart -->
                    <VBox spacing="10" styleClass="dark-panel">
                        <Label text="Current Order Items" styleClass="label-strong"/>
                        <TableView fx:id="poTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colMedicine" text="Medicine" prefWidth="200"/>
                                <TableColumn fx:id="colCompany" text="Company" prefWidth="120"/>
                                <TableColumn fx:id="colQty" text="Qty" prefWidth="80"/>
                                <TableColumn fx:id="colCost" text="Unit Cost" prefWidth="100"/>
                                <TableColumn fx:id="colTotal" text="Total" prefWidth="100"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>

                        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="dark-section">
                            <Label text="Order Total:" styleClass="total-label"/>
                            <Label fx:id="lblTotalAmount" text="₹ 0.00" styleClass="total-value"/>
                        </HBox>
                        
                        <Button text="🗑 Remove Selected Item" onAction="#handleRemoveItem" styleClass="button-outlined"/>
                    </VBox>

                    <!-- Right: Controls -->
                    <VBox spacing="15" styleClass="billing-controls">
                        <!-- Supplier Section -->
                        <VBox spacing="5" styleClass="billing-section">
                            <Label text="1. Select Supplier" styleClass="label-strong"/>
                            <ComboBox fx:id="comboSupplier" promptText="Select Supplier" maxWidth="Infinity"/>
                            <TextField fx:id="txtNotes" promptText="Order Notes / Invoice #"/>
                        </VBox>

                        <!-- Item Entry Section -->
                        <VBox spacing="10" styleClass="billing-section" VBox.vgrow="ALWAYS">
                            <Label text="2. Add Items to Order" styleClass="label-strong"/>

                            <VBox spacing="2">
                                <Label text="Search Medicine"/>
                                <StackPane alignment="TOP_LEFT">
                                    <TextField fx:id="txtSearchMedicine" promptText="Type medicine name..."/>
                                    <ListView fx:id="listMedicineSuggestions" visible="false" maxHeight="150"/>
                                </StackPane>
                            </VBox>

                            <HBox spacing="10">
                                <VBox spacing="2" HBox.hgrow="ALWAYS">
                                    <Label text="Received Qty"/>
                                    <TextField fx:id="txtQty" promptText="e.g. 50"/>
                                </VBox>
                                <VBox spacing="2" HBox.hgrow="ALWAYS">
                                    <Label text="Unit Cost (₹)"/>
                                    <TextField fx:id="txtCost" promptText="e.g. 10.50"/>
                                </VBox>
                            </HBox>
                            
                            <Button text="ADD TO ORDER" onAction="#handleAddItem" styleClass="button-primary" maxWidth="Infinity" prefHeight="40"/>
                            <Region VBox.vgrow="ALWAYS"/>
                        </VBox>

                        <!-- Receive Button -->
                        <Button fx:id="btnReceiveOrder" text="RECEIVE ORDER &amp; UPDATE STOCK" onAction="#handleReceiveOrder" maxWidth="Infinity" prefHeight="60" styleClass="button-success button-xl"/>
                    </VBox>
                </SplitPane>
            </Tab>

            <!-- Tab 2: Purchase History -->
            <Tab text="Purchase History">
                <VBox spacing="10" styleClass="dark-panel">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button text="🔄 Refresh History" onAction="#handleRefreshHistory" styleClass="button-outlined"/>
                    </HBox>
                    <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="histColId" text="PO #" prefWidth="80"/>
                            <TableColumn fx:id="histColDate" text="Date" prefWidth="150"/>
                            <TableColumn fx:id="histColSupplier" text="Supplier" prefWidth="200"/>
                            <TableColumn fx:id="histColAmount" text="Amount" prefWidth="120"/>
                            <TableColumn fx:id="histColStatus" text="Status" prefWidth="100"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                    <Label text="Double-click a row to view items." styleClass="text-muted"/>
                </VBox>
            </Tab>

        </TabPane>
    </VBox>
</VBox>

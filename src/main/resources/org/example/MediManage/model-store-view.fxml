<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.MediManage.ModelStoreController" prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #f4f6f8;">

    <top>
        <VBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 0, 5, 10, 0);">
            <Label text="AI Model Store" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Label text="Download high-performance local models optimized for your hardware." style="-fx-text-fill: #666;"/>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search Hugging Face Models..." HBox.hgrow="ALWAYS" style="-fx-padding: 10;"/>
                <Button text="Search" onAction="#handleSearch" style="-fx-background-color: #1976d2; -fx-text-fill: white; -fx-padding: 10 20;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-padding: 20;">
            <TilePane fx:id="modelsContainer" hgap="20" vgap="20" style="-fx-background-color: transparent;"/>
        </ScrollPane>
    </center>

    <bottom>
        <VBox spacing="5" style="-fx-padding: 15; -fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0;">
            <Label fx:id="statusLabel" text="Ready" style="-fx-font-weight: bold;"/>
            <ProgressBar fx:id="globalProgressBar" progress="0.0" maxWidth="1.7976931348623157E308"/>
        </VBox>
    </bottom>

</BorderPane>

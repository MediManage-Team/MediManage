<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20"
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.MediManage.ReportsController" styleClass="dark-panel">

    <!-- Header -->
    <HBox spacing="15" alignment="CENTER_LEFT" styleClass="card">
        <Label text="Sales Reports" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="From:"/>
        <DatePicker fx:id="dateStart" prefWidth="120"/>
        <Label text="To:"/>
        <DatePicker fx:id="dateEnd" prefWidth="120"/>
        <Button text="Generate Report" onAction="#handleGenerate" styleClass="button-primary"/>
    </HBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- Summary Card -->
        <VBox spacing="10" minWidth="250" styleClass="card">
            <Label text="Total Revenue (Selected Period)" styleClass="text-muted"/>
            <Label fx:id="lblTotalRevenue" text="₹ 0.00" styleClass="total-value"/>
            <Separator/>
            <Label text="Top Categories (Coming Soon)" styleClass="text-muted" style="-fx-font-style: italic;"/>
        </VBox>

        <!-- Chart -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS">
            <Label text="Sales Trend" styleClass="section-title"/>
            <LineChart fx:id="salesChart" title="Daily Sales">
                <xAxis>
                    <CategoryAxis fx:id="xAxis" label="Date"/>
                </xAxis>
                <yAxis>
                    <NumberAxis fx:id="yAxis" label="Revenue (₹)"/>
                </yAxis>
            </LineChart>
        </VBox>
    </HBox>
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" styleClass="dark-panel" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.MediManage.controller.ExpensesController">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="💸 Expense Management" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        
        <VBox alignment="CENTER_RIGHT" style="-fx-background-color: #2D2D3D; -fx-padding: 10 20; -fx-background-radius: 8; -fx-border-color: #4A4A6A; -fx-border-radius: 8;">
            <Label text="Monthly Expenses" style="-fx-text-fill: #A0A0B0; -fx-font-size: 11px;"/>
            <Label fx:id="lblMonthlyTotal" text="₹ 0.00" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #FF6B6B;"/>
        </VBox>
    </HBox>

    <SplitPane dividerPositions="0.30" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
        <!-- Left Sidebar: Add New Expense -->
        <VBox spacing="15" styleClass="dark-section" maxWidth="350" minWidth="250">
            <Label text="Record Expense" styleClass="section-title"/>
            
            <VBox spacing="5">
                <Label text="Date" style="-fx-font-weight: bold;"/>
                <DatePicker fx:id="datePicker" maxWidth="Infinity" promptText="Select Date"/>
            </VBox>
            
            <VBox spacing="5">
                <Label text="Category" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="comboCategory" editable="true" maxWidth="Infinity" promptText="e.g., Rent, Salary, Utilities"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Amount (₹)" style="-fx-font-weight: bold;"/>
                <TextField fx:id="txtAmount" promptText="0.00"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Description (Optional)" style="-fx-font-weight: bold;"/>
                <TextArea fx:id="txtDescription" prefRowCount="3" wrapText="true" promptText="Any extra details..."/>
            </VBox>

            <Button text="➕ ADD EXPENSE" onAction="#handleAddExpense" maxWidth="Infinity" prefHeight="45" styleClass="button-success"/>
        </VBox>

        <!-- Right Side: Expense History -->
        <VBox spacing="10" styleClass="dark-panel">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Recent Expenses" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="🗑 Delete Selected" onAction="#handleDeleteExpense" styleClass="button-danger"/>
                <Button text="🔄 Refresh" onAction="#loadExpenses" styleClass="button-outlined"/>
            </HBox>

            <TableView fx:id="expenseTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colDate" text="Date" prefWidth="120"/>
                    <TableColumn fx:id="colCategory" text="Category" prefWidth="150"/>
                    <TableColumn fx:id="colAmount" text="Amount (₹)" prefWidth="120"/>
                    <TableColumn fx:id="colDesc" text="Description" prefWidth="250"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>
    </SplitPane>
</VBox>

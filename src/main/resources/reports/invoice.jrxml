<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
    name="Invoice" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">

    <parameter name="CustomerName" class="java.lang.String"/>
    <parameter name="TotalAmount" class="java.lang.Double"/>
    <parameter name="CareProtocol" class="java.lang.String"/>
    <parameter name="PrescriptionHighlights" class="java.lang.String"/>
    <parameter name="PrescriptionHighlightsHtml" class="java.lang.String"/>
    <parameter name="PrescriptionScheduleText" class="java.lang.String"/>
    <parameter name="HasPrescriptionHighlights" class="java.lang.Boolean"/>
    <parameter name="HasPrescriptionSchedule" class="java.lang.Boolean"/>
    <parameter name="PrescriptionScheduleReport" class="net.sf.jasperreports.engine.JasperReport"/>
    <parameter name="PrescriptionScheduleDataSource" class="net.sf.jasperreports.engine.JRDataSource"/>
    <parameter name="PharmacyName" class="java.lang.String"/>
    <parameter name="AddressBlock" class="java.lang.String"/>
    <parameter name="ContactLine" class="java.lang.String"/>
    <parameter name="FooterText" class="java.lang.String"/>
    <parameter name="DocumentNumber" class="java.lang.String"/>
    <parameter name="LogoImage" class="java.awt.Image"/>

    <parameter name="SubscriptionPlanName" class="java.lang.String"/>
    <parameter name="SubscriptionSavings" class="java.lang.Double"/>
    <parameter name="SubscriptionDiscountPercent" class="java.lang.Double"/>
    <parameter name="SubscriptionExplanationLanguage" class="java.lang.String"/>
    <parameter name="SubscriptionExplanationSnippet" class="java.lang.String"/>

    <field name="name" class="java.lang.String"/>
    <field name="qty" class="java.lang.Integer"/>
    <field name="price" class="java.lang.Double"/>
    <field name="total" class="java.lang.Double"/>

    <title>
        <band height="128">
            <image scaleImage="RetainShape" onErrorType="Blank">
                <reportElement x="0" y="0" width="68" height="54">
                    <printWhenExpression><![CDATA[$P{LogoImage} != null]]></printWhenExpression>
                </reportElement>
                <imageExpression><![CDATA[$P{LogoImage}]]></imageExpression>
            </image>

            <textField>
                <reportElement x="78" y="0" width="360" height="24"/>
                <textElement>
                    <font size="18" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{PharmacyName}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="78" y="26" width="220" height="20"/>
                <textElement>
                    <font size="13" isBold="true"/>
                </textElement>
                <text><![CDATA[Medical Invoice]]></text>
            </staticText>

            <textField>
                <reportElement x="385" y="26" width="170" height="20"/>
                <textElement textAlignment="Right">
                    <font size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{DocumentNumber} == null ? "" : $P{DocumentNumber}]]></textFieldExpression>
            </textField>

            <textField textAdjust="StretchHeight">
                <reportElement x="78" y="50" width="477" height="18"/>
                <textElement>
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{AddressBlock} == null ? "" : $P{AddressBlock}]]></textFieldExpression>
            </textField>

            <textField textAdjust="StretchHeight">
                <reportElement x="78" y="72" width="477" height="18"/>
                <textElement>
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{ContactLine} == null ? "" : $P{ContactLine}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="0" y="98" width="555" height="1"/>
            </line>

            <textField>
                <reportElement x="0" y="106" width="555" height="18"/>
                <textElement>
                    <font size="10" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Customer: " + $P{CustomerName}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="30">
            <staticText>
                <reportElement x="0" y="0" width="255" height="30"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Item]]></text>
            </staticText>
            <staticText>
                <reportElement x="255" y="0" width="80" height="30"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Qty]]></text>
            </staticText>
            <staticText>
                <reportElement x="335" y="0" width="100" height="30"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Price]]></text>
            </staticText>
            <staticText>
                <reportElement x="435" y="0" width="120" height="30"/>
                <textElement textAlignment="Right">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Total]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20" splitType="Stretch">
            <textField textAdjust="StretchHeight">
                <reportElement x="0" y="0" width="255" height="20"/>
                <textFieldExpression><![CDATA[$F{name}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="255" y="0" width="80" height="20"/>
                <textFieldExpression><![CDATA[$F{qty}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="335" y="0" width="100" height="20"/>
                <textFieldExpression><![CDATA[String.format("%.2f", $F{price})]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="435" y="0" width="120" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[String.format("%.2f", $F{total})]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="420" splitType="Stretch">
            <textField>
                <reportElement x="350" y="10" width="205" height="30"/>
                <textElement textAlignment="Right">
                    <font size="14" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Total: " + String.format("%.2f", $P{TotalAmount})]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="10" width="340" height="20"/>
                <textFieldExpression><![CDATA[$P{SubscriptionPlanName} == null || $P{SubscriptionPlanName}.trim().isEmpty()
? ""
: "Subscription Plan: " + $P{SubscriptionPlanName}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="30" width="340" height="20"/>
                <textFieldExpression><![CDATA[$P{SubscriptionSavings} == null || $P{SubscriptionSavings}.doubleValue() <= 0
? ""
: "Subscription Savings: " + String.format("%.2f", $P{SubscriptionSavings})]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="50" width="340" height="20"/>
                <textFieldExpression><![CDATA[$P{SubscriptionDiscountPercent} == null || $P{SubscriptionDiscountPercent}.doubleValue() <= 0
? ""
: "Subscription Discount %: " + String.format("%.2f", $P{SubscriptionDiscountPercent})]]></textFieldExpression>
            </textField>

            <textField textAdjust="StretchHeight">
                <reportElement x="0" y="72" width="555" height="36"/>
                <textElement>
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{SubscriptionExplanationSnippet} == null || $P{SubscriptionExplanationSnippet}.trim().isEmpty()
? ""
: "Savings Explanation (" + ($P{SubscriptionExplanationLanguage} == null || $P{SubscriptionExplanationLanguage}.trim().isEmpty() ? "English" : $P{SubscriptionExplanationLanguage}) + "): " + $P{SubscriptionExplanationSnippet}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement positionType="Float" x="0" y="114" width="555" height="1"/>
            </line>

            <subreport isUsingCache="false">
                <reportElement positionType="Float" x="0" y="124" width="555" height="120" isRemoveLineWhenBlank="true">
                    <printWhenExpression><![CDATA[Boolean.TRUE.equals($P{HasPrescriptionHighlights}) || Boolean.TRUE.equals($P{HasPrescriptionSchedule})]]></printWhenExpression>
                </reportElement>
                <subreportParameter name="PrescriptionHighlightsHtml">
                    <subreportParameterExpression><![CDATA[$P{PrescriptionHighlightsHtml}]]></subreportParameterExpression>
                </subreportParameter>
                <subreportParameter name="HasPrescriptionHighlights">
                    <subreportParameterExpression><![CDATA[$P{HasPrescriptionHighlights}]]></subreportParameterExpression>
                </subreportParameter>
                <subreportParameter name="HasPrescriptionSchedule">
                    <subreportParameterExpression><![CDATA[$P{HasPrescriptionSchedule}]]></subreportParameterExpression>
                </subreportParameter>
                <dataSourceExpression><![CDATA[$P{PrescriptionScheduleDataSource}]]></dataSourceExpression>
                <subreportExpression><![CDATA[$P{PrescriptionScheduleReport}]]></subreportExpression>
            </subreport>

            <line>
                <reportElement positionType="Float" x="0" y="252" width="555" height="1"/>
            </line>

            <staticText>
                <reportElement positionType="Float" x="0" y="262" width="555" height="20"/>
                <textElement>
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[Patient Care Protocol (AI Generated):]]></text>
            </staticText>

            <textField textAdjust="StretchHeight">
                <reportElement positionType="Float" stretchType="ElementGroupHeight" x="0" y="287" width="555" height="20" isPrintWhenDetailOverflows="true"/>
                <textElement markup="html">
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{CareProtocol} == null || $P{CareProtocol}.trim().isEmpty() ? "No additional AI care protocol generated." : $P{CareProtocol}.replaceAll("\n", "<br>")]]></textFieldExpression>
            </textField>

            <line>
                <reportElement positionType="Float" x="0" y="314" width="555" height="1"/>
            </line>

            <textField textAdjust="StretchHeight">
                <reportElement positionType="Float" x="0" y="322" width="555" height="22"/>
                <textElement textAlignment="Center">
                    <font size="10" isItalic="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{FooterText} == null ? "" : $P{FooterText}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>
